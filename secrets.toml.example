# Copy this file to secrets.toml (which is gitignored) and fill in the real
# values from `turso db show <db> --url` and `turso db tokens create <db>`.
# The same two keys go into Streamlit Community Cloud's Secrets box on deploy.
#
# With these set, db.get_conn() talks to Turso. With them absent, it falls back
# to the local family_finance.db for offline/dev work.

TURSO_DATABASE_URL = "libsql://personal-finance-<org>.turso.io"
TURSO_AUTH_TOKEN   = "paste-full-read-write-token-here"

# Access gate for the public Streamlit Cloud deployment. The app shows nothing and
# runs no queries until this passphrase is entered. Use a long one. If unset (local
# dev), the gate is open.
APP_PASSWORD       = "choose-a-long-passphrase"
